	set draftCount to 0

	tell application "Microsoft Outlook"
		repeat with recInfo in recipientList
			set recipEmail to item 1 of recInfo
			set recipLastName to item 2 of recInfo
			set recipTemplate to item 3 of recInfo

			-- Select the right template body
			if recipTemplate is "STEM" then
				set templateBody to stemBody
			else if recipTemplate is "Humanities" then
				set templateBody to humanitiesBody
			else if recipTemplate is "SocialSci" then
				set templateBody to socialSciBody
			else
				set templateBody to profBody
			end if

			-- Build the full body with greeting
			set fullBody to "Good morning, Prof. " & recipLastName & "," & return & return & templateBody

			-- Create the draft message
			set newMsg to make new outgoing message with properties {subject:emailSubject, content:fullBody}

			-- Add to recipient
			make new to recipient at newMsg with properties {email address:{address:recipEmail}}

			set draftCount to draftCount + 1
		end repeat
	end tell

	display dialog "Done! Created " & draftCount & " draft emails in Outlook." buttons {"OK"} default button "OK"
	return draftCount
end run
